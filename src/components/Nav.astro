---
import { getUser } from "../lib/auth";
const { user } = await getUser(Astro as any);
---
<header class="sticky top-0 z-40 backdrop-blur-md bg-[#1b1209]/85 border-b border-rune-gold/30">
  <div class="max-w-7xl mx-auto px-4 md:px-6 py-3 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2 group">
      <span class="text-2xl">⚔️</span>
      <span class="font-display font-bold text-xl md:text-2xl shimmer group-hover:brightness-110">FashionScape Hub</span>
    </a>
    <nav class="hidden md:flex items-center gap-6 text-sm">
      <a href="/outfits" class="hover:text-rune-gold transition">Gallery</a>
      <a href="/weekly" class="hover:text-rune-gold transition">🏆 Weekly</a>
      <a href="/achievements" class="hover:text-rune-gold transition">🎖 Achievements</a>
      <a href="/leaderboard" class="hover:text-rune-gold transition">📜 Leaderboard</a>
    </nav>
    <div class="flex items-center gap-2">
      {user ? (
        <>
          <a href="/upload" class="btn-gold px-3 py-1.5 md:px-4 md:py-2 rounded text-xs md:text-sm">+ Upload</a>
          <a href="/me" class="rune-border px-3 py-1.5 rounded text-xs md:text-sm hover:border-rune-gold transition">My Scape</a>
        </>
      ) : (
        <>
          <a href="/login" class="rune-border px-3 py-1.5 rounded text-xs md:text-sm hover:border-rune-gold transition">Log in</a>
          <a href="/signup" class="btn-gold px-3 py-1.5 md:px-4 md:py-2 rounded text-xs md:text-sm">Join the realm</a>
        </>
      )}
    </div>
  </div>
  <div class="md:hidden border-t border-rune-gold/20 overflow-x-auto">
    <div class="flex gap-5 px-4 py-2 text-xs whitespace-nowrap">
      <a href="/outfits" class="hover:text-rune-gold">Gallery</a>
      <a href="/weekly" class="hover:text-rune-gold">🏆 Weekly</a>
      <a href="/achievements" class="hover:text-rune-gold">🎖 Achievements</a>
      <a href="/leaderboard" class="hover:text-rune-gold">📜 Leaderboard</a>
    </div>
  </div>
</header>
