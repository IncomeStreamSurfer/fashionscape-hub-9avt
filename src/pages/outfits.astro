---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import OutfitCard from "../components/OutfitCard.astro";
import { getSupabase, CATEGORIES } from "../lib/supabase";

const supa = getSupabase();
const selectedCat = Astro.url.searchParams.get("category");
const sort = Astro.url.searchParams.get("sort") || "new";

let q = supa
  .from("outfits")
  .select("id,title,image_url,category,vote_count,discord_url,profiles(username)")
  .limit(60);

if (selectedCat) q = q.eq("category", selectedCat);
if (sort === "top") q = q.order("vote_count", { ascending: false });
else q = q.order("created_at", { ascending: false });

const { data: outfits } = await q;
---
<Base title="Outfit Gallery — FashionScape Hub">
  <Nav />
  <main class="max-w-7xl mx-auto px-6 py-10">
    <div class="mb-8">
      <div class="text-xs uppercase tracking-widest text-rune-gold/80 mb-1">📜 The archives</div>
      <h1 class="font-display text-4xl md:text-5xl font-bold">Outfit Gallery</h1>
      <p class="text-parchment/60 mt-2">Browse every outfit in the realm. Vote, remix, get inspired.</p>
    </div>

    <div class="flex flex-wrap gap-2 mb-6">
      <a href="/outfits" class={`px-3 py-1.5 text-sm rounded rune-border ${!selectedCat ? 'border-rune-gold bg-rune-gold/10 text-rune-gold' : ''}`}>All</a>
      {CATEGORIES.map((c) => (
        <a href={`/outfits?category=${c.id}${sort === 'top' ? '&sort=top' : ''}`} class={`px-3 py-1.5 text-sm rounded rune-border flex items-center gap-1 ${selectedCat === c.id ? 'border-rune-gold bg-rune-gold/10' : ''}`} style={selectedCat === c.id ? `color: ${c.color}; border-color: ${c.color};` : ''}>
          <span>{c.icon}</span><span>{c.label}</span>
        </a>
      ))}
    </div>

    <div class="flex gap-2 mb-8 text-sm">
      <a href={`/outfits${selectedCat ? `?category=${selectedCat}` : ''}`} class={`px-3 py-1 rounded ${sort !== 'top' ? 'bg-rune-gold text-[#1b1209] font-bold' : 'rune-border'}`}>🆕 New</a>
      <a href={`/outfits?${selectedCat ? `category=${selectedCat}&` : ''}sort=top`} class={`px-3 py-1 rounded ${sort === 'top' ? 'bg-rune-gold text-[#1b1209] font-bold' : 'rune-border'}`}>🔥 Top voted</a>
    </div>

    {outfits && outfits.length > 0 ? (
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
        {outfits.map((o: any) => <OutfitCard outfit={o} />)}
      </div>
    ) : (
      <div class="rune-border rounded-xl p-10 text-center">
        <div class="text-6xl mb-4">🏜️</div>
        <h3 class="font-display text-2xl mb-2">No outfits here yet</h3>
        <p class="text-parchment/60 mb-6">Be the first to upload in this category and claim the glory.</p>
        <a href="/upload" class="btn-gold px-6 py-3 rounded inline-block">Upload an outfit →</a>
      </div>
    )}
  </main>
  <Footer />
</Base>
