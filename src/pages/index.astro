---
import Base from "../layouts/Base.astro";
---
<Base title="FashionScape Hub — Building...">
  <main class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center max-w-2xl">
      <div class="inline-block text-6xl md:text-7xl font-display font-bold shimmer mb-6 pulse-build">
        FashionScape Hub
      </div>
      <p class="text-xl md:text-2xl text-parchment/80 font-display mb-8">⚔️ Forging the realm's finest fashionscape showcase...</p>
      <div class="flex gap-3 justify-center items-center">
        <span class="inline-block w-3 h-3 rounded-full bg-rune-gold animate-bounce" style="animation-delay:0s"></span>
        <span class="inline-block w-3 h-3 rounded-full bg-rune-gold animate-bounce" style="animation-delay:0.15s"></span>
        <span class="inline-block w-3 h-3 rounded-full bg-rune-gold animate-bounce" style="animation-delay:0.3s"></span>
      </div>
      <p class="mt-10 text-parchment/50 text-sm">Summoning outfits, achievements, and weekly awards...</p>
    </div>
  </main>
</Base>
