---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { getUser } from "../lib/auth";
import { CATEGORIES } from "../lib/supabase";

const { user } = await getUser(Astro as any);
if (!user) return Astro.redirect("/login?error=Please%20log%20in%20to%20upload");
const error = Astro.url.searchParams.get("error");
const preselect = Astro.url.searchParams.get("category") || "general";
---
<Base title="Upload an outfit — FashionScape Hub">
  <Nav />
  <main class="max-w-2xl mx-auto px-6 py-10">
    <div class="text-center mb-8">
      <div class="text-5xl mb-3">📤</div>
      <h1 class="font-display text-4xl font-bold shimmer">Upload your fashionscape</h1>
      <p class="text-parchment/70 mt-2">Show off your drip. Link your Discord for bonus points.</p>
    </div>

    {error && <div class="rune-border rounded p-3 mb-4 text-blood bg-blood/10 text-sm text-center">{error}</div>}

    <form method="POST" action="/api/upload" enctype="multipart/form-data" class="rune-border rounded-xl p-6 space-y-5">
      <div>
        <label class="block text-xs uppercase tracking-widest text-rune-gold/80 mb-1">Outfit title</label>
        <input name="title" required maxlength="60" class="w-full bg-[#1b1209] border border-rune-gold/40 rounded px-3 py-2 focus:border-rune-gold outline-none" placeholder="Max str bonus drip" />
      </div>

      <div>
        <label class="block text-xs uppercase tracking-widest text-rune-gold/80 mb-1">Category</label>
        <select name="category" required class="w-full bg-[#1b1209] border border-rune-gold/40 rounded px-3 py-2 focus:border-rune-gold outline-none">
          {CATEGORIES.map((c) => (
            <option value={c.id} selected={c.id === preselect}>{c.icon} {c.label}</option>
          ))}
        </select>
      </div>

      <div>
        <label class="block text-xs uppercase tracking-widest text-rune-gold/80 mb-1">Outfit image</label>
        <input name="image" type="file" accept="image/*" required class="w-full text-sm file:mr-3 file:py-2 file:px-3 file:rounded file:border-0 file:bg-rune-gold file:text-[#1b1209] file:font-bold" />
        <p class="text-xs text-parchment/50 mt-1">PNG or JPG, max 5MB. Show off the full outfit.</p>
      </div>

      <div>
        <label class="block text-xs uppercase tracking-widest text-rune-gold/80 mb-1">Description <span class="text-parchment/40 normal-case tracking-normal">(optional)</span></label>
        <textarea name="description" rows="3" maxlength="500" class="w-full bg-[#1b1209] border border-rune-gold/40 rounded px-3 py-2 focus:border-rune-gold outline-none" placeholder="Armor set, cape, weapon..."></textarea>
      </div>

      <div>
        <label class="block text-xs uppercase tracking-widest text-rune-gold/80 mb-1">Items used <span class="text-parchment/40 normal-case tracking-normal">(optional)</span></label>
        <input name="items" class="w-full bg-[#1b1209] border border-rune-gold/40 rounded px-3 py-2 focus:border-rune-gold outline-none" placeholder="Torva helm, Amulet of fury, Abyssal whip (comma separated)" />
      </div>

      <div>
        <label class="block text-xs uppercase tracking-widest text-rune-gold/80 mb-1">Discord invite URL <span class="text-parchment/40 normal-case tracking-normal">(+5 bonus points)</span></label>
        <input name="discord_url" type="url" class="w-full bg-[#1b1209] border border-rune-gold/40 rounded px-3 py-2 focus:border-rune-gold outline-none" placeholder="https://discord.gg/yourserver" />
        <p class="text-xs text-[#5865f2]/80 mt-1">💬 Viewers can click to join your Discord — extra engagement, extra points.</p>
      </div>

      <button type="submit" class="btn-gold w-full py-3 rounded font-bold text-lg">Submit to the realm ⚔️</button>
    </form>
  </main>
  <Footer />
</Base>
