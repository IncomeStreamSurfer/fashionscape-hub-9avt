---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { getUser } from "../lib/auth";
const { user } = await getUser(Astro as any);
if (user) return Astro.redirect("/me");
const error = Astro.url.searchParams.get("error");
---
<Base title="Join the realm — FashionScape Hub">
  <Nav />
  <main class="max-w-md mx-auto px-6 py-16">
    <div class="text-center mb-8">
      <div class="text-5xl mb-4">⚔️</div>
      <h1 class="font-display text-4xl font-bold shimmer">Join the realm</h1>
      <p class="text-parchment/70 mt-2">Create your fashionscape profile and start earning points.</p>
    </div>
    {error && <div class="rune-border rounded p-3 mb-4 text-blood bg-blood/10 text-sm text-center">{error}</div>}
    <form method="POST" action="/api/signup" class="rune-border rounded-xl p-6 space-y-4">
      <div>
        <label class="block text-xs uppercase tracking-widest text-rune-gold/80 mb-1">Username</label>
        <input name="username" required minlength="3" maxlength="24" pattern="[a-zA-Z0-9_-]+" class="w-full bg-[#1b1209] border border-rune-gold/40 rounded px-3 py-2 focus:border-rune-gold outline-none" placeholder="Zezima" />
        <p class="text-xs text-parchment/50 mt-1">Letters, numbers, dashes, underscores.</p>
      </div>
      <div>
        <label class="block text-xs uppercase tracking-widest text-rune-gold/80 mb-1">Email</label>
        <input name="email" type="email" required class="w-full bg-[#1b1209] border border-rune-gold/40 rounded px-3 py-2 focus:border-rune-gold outline-none" />
      </div>
      <div>
        <label class="block text-xs uppercase tracking-widest text-rune-gold/80 mb-1">Password</label>
        <input name="password" type="password" required minlength="6" class="w-full bg-[#1b1209] border border-rune-gold/40 rounded px-3 py-2 focus:border-rune-gold outline-none" />
      </div>
      <div>
        <label class="block text-xs uppercase tracking-widest text-rune-gold/80 mb-1">Discord handle <span class="text-parchment/40 normal-case tracking-normal">(optional, +15 pts)</span></label>
        <input name="discord_handle" class="w-full bg-[#1b1209] border border-rune-gold/40 rounded px-3 py-2 focus:border-rune-gold outline-none" placeholder="zezima#0001" />
      </div>
      <button type="submit" class="btn-gold w-full py-3 rounded font-bold">Forge your account →</button>
      <p class="text-xs text-parchment/60 text-center">Already an adventurer? <a href="/login" class="text-rune-gold hover:underline">Log in</a></p>
    </form>
  </main>
  <Footer />
</Base>
